{
  "manifest_version": 3,
  "name": "TabFlip",
  "version": "1.3.1",
  "version_name": "1.3.1",
  "description": "Switch tabs like Arc. Hold Ctrl+Q to see your 5 recent tabs with visual previews. Release Ctrl to switch.",
  "homepage_url": "https://buymeacoffee.com/abidalista",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "cycle-tab": {
      "suggested_key": {
        "default": "Ctrl+Q",
        "mac": "MacCtrl+Q"
      },
      "description": "Cycle through recent tabs"
    }
  }
}
